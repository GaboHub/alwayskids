---
import { site } from '../lib/site';

const { tematicasCombinables } = site;
---

<section class="rounded-3xl bg-amarillo/15 p-6 md:p-8">
  <h2 class="font-titulos text-2xl font-extrabold text-tinta">🔀 Temáticas combinables</h2>
  <p class="mt-3 font-texto text-tinta">{tematicasCombinables.texto}</p>
  <ul class="mt-4 flex flex-col gap-2">
    {
      tematicasCombinables.ejemplos.map((ejemplo) => (
        <li class="flex gap-2 font-texto text-tinta">
          <span aria-hidden="true">🎈</span>
          <span>{ejemplo}</span>
        </li>
      ))
    }
  </ul>
  <p class="mt-4 font-texto font-semibold text-tinta">{tematicasCombinables.cierre}</p>
</section>
