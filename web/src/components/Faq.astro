---
import type { FaqItem } from '../lib/faqs';

interface Props {
  items: FaqItem[];
  titulo?: string;
}

const { items, titulo = 'Preguntas frecuentes' } = Astro.props;
---

<section class="mx-auto max-w-4xl px-4 py-12" aria-labelledby="faq-titulo">
  <h2 id="faq-titulo" class="font-titulos text-2xl font-extrabold text-tinta md:text-3xl">
    {titulo}
  </h2>
  <div class="mt-6 flex flex-col gap-3">
    {
      items.map((item) => (
        <details class="group rounded-2xl bg-white p-5 shadow-sm ring-1 ring-black/5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-titulos font-bold text-tinta [&::-webkit-details-marker]:hidden">
            <span>{item.pregunta}</span>
            <span aria-hidden="true" class="shrink-0 text-menta-dark transition-transform group-open:rotate-45">
              +
            </span>
          </summary>
          <p class="mt-3 font-texto text-tinta/80">{item.respuesta}</p>
        </details>
      ))
    }
  </div>
</section>
