---
import { site } from '../lib/site';
import { redes } from '../lib/redes';

const anio = new Date().getFullYear();
---

<footer class="mt-16 border-t border-menta-light bg-menta-dark text-white">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <p class="font-titulos text-xl font-extrabold">{site.nombre}</p>
        <p class="mt-2 text-sm text-white/90">{site.tagline}</p>
        <p class="mt-4 text-sm text-white/90">{site.footer}</p>
      </div>
      <div class="text-sm">
        <p class="font-titulos text-base font-bold">Contacto</p>
        <p class="mt-2">
          <a href={`tel:${site.telefonoE164}`} class="hover:underline">{site.telefono}</a>
        </p>
        <p class="mt-1">{site.ubicacion}</p>
        <p class="mt-1">{site.cobertura}</p>
        <p class="mt-3">
          <a href="/terminos-y-condiciones/" class="underline hover:text-amarillo">Términos y condiciones</a>
        </p>
      </div>
      <div class="text-sm">
        <p class="font-titulos text-base font-bold">Síguenos</p>
        <div class="mt-3 flex gap-3">
          {
            redes.map((red) => (
              <a
                href={red.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={red.nombre}
                class="flex h-10 w-10 items-center justify-center rounded-full bg-white/15 transition-colors hover:bg-white/30"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                  <path d={red.icono} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </div>
    <p class="mt-8 border-t border-white/20 pt-6 text-center text-xs text-white/80">
      © {anio} {site.nombre}. Todos los derechos reservados.
    </p>
  </div>
</footer>
