---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  nombre: string;
  emoji: string;
  resumen: string;
  imagen?: ImageMetadata;
  altImagen?: string;
}

const { href, nombre, emoji, resumen, imagen, altImagen } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-black/5 transition-transform hover:-translate-y-1 hover:shadow-lg"
>
  {
    imagen && (
      <Image
        src={imagen}
        alt={altImagen ?? nombre}
        width={480}
        height={320}
        class="h-40 w-full object-cover sm:h-48"
      />
    )
  }
  <div class="flex flex-1 flex-col gap-2 p-5">
    <p class="font-titulos text-lg font-extrabold text-tinta">
      <span aria-hidden="true">{emoji}</span> {nombre}
    </p>
    <p class="font-texto text-sm text-tinta/80">{resumen}</p>
    <span class="mt-auto pt-2 font-texto text-sm font-bold text-menta-dark group-hover:text-rosado">
      Ver más →
    </span>
  </div>
</a>
