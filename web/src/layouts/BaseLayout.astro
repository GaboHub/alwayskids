---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { site, siteUrl } from '../lib/site';
import { resolveImage, ogFormat } from '../lib/images';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: ImageMetadata;
  jsonLd: object[];
  noindex?: boolean;
}

const { title, description, path, ogImage, jsonLd, noindex = false } = Astro.props;

const logo = resolveImage('logo');
const imagenFuente = ogImage ?? logo;
const imagenSocialOptimizada = await getImage({
  src: imagenFuente,
  width: 630,
  format: ogFormat(imagenFuente),
  quality: 65,
});

const canonicalUrl = new URL(path, siteUrl).toString();
const ogImageUrl = new URL(imagenSocialOptimizada.src, siteUrl).toString();
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.nombre} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(imagenSocialOptimizada.attributes.width)} />
    <meta property="og:image:height" content={String(imagenSocialOptimizada.attributes.height)} />
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      jsonLd.map((entrada) => (
        <script type="application/ld+json" set:html={JSON.stringify(entrada)} is:inline />
      ))
    }
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
  </body>
</html>
