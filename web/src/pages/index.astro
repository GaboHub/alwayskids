---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ServiciosTematicos from '../components/ServiciosTematicos.astro';
import CtaWhatsApp from '../components/CtaWhatsApp.astro';
import Globos from '../components/Globos.astro';
import Faq from '../components/Faq.astro';
import { site } from '../lib/site';
import { faqs } from '../lib/faqs';
import { resolveImage, optimizedAbsoluteUrl } from '../lib/images';
import { buildLocalBusiness, buildWebSite, buildFaqPage } from '../lib/seo';

const inicio = await getEntry('paginas', 'inicio');
if (!inicio) throw new Error('Falta la página inicio');
const { Content } = await render(inicio);

const logo = resolveImage('logo');

const title = `Inicio | ${site.nombre} — Animación de fiestas infantiles a domicilio en Santiago`;
const description =
  'Animación infantil a domicilio en Santiago: cumpleaños deportivos, científicos y plazas blandas para bebés. Monitores profesionales en toda la Región Metropolitana.';

const logoUrl = await optimizedAbsoluteUrl(logo);
const jsonLd = [buildLocalBusiness(logoUrl), buildWebSite(), buildFaqPage(faqs.global)];
---

<BaseLayout title={title} description={description} path="/" ogImage={logo} jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-gradient-to-b from-menta-light to-crema px-4 py-14 text-center md:py-20">
    <Globos class="absolute -top-4 left-1/2 h-40 w-64 -translate-x-1/2 md:h-56 md:w-96" />
    <div class="relative mx-auto flex max-w-3xl flex-col items-center gap-5">
      <Image src={logo} alt="Logo de Always Kids" width={120} height={120} class="h-24 w-24 rounded-full shadow-md md:h-32 md:w-32" priority />
      <h1 class="font-titulos text-3xl font-extrabold leading-tight text-tinta md:text-5xl">
        {site.tagline}
      </h1>
      <p class="font-texto text-lg text-tinta/80 md:text-xl">{site.claim}</p>
      <CtaWhatsApp texto="Cotiza tu fiesta por WhatsApp" />
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-12">
    <div class="contenido-md">
      <Content />
    </div>
  </section>

  <ServiciosTematicos />

  <section id="categorias" aria-labelledby="categorias-titulo" class="bg-white px-4 py-14">
    <div class="mx-auto max-w-6xl">
      <h2 id="categorias-titulo" class="text-center font-titulos text-3xl font-extrabold text-tinta">
        Nuestros servicios
      </h2>
      <p class="mx-auto mt-2 max-w-2xl text-center font-texto text-tinta/70">
        Elige la categoría de animación ideal para tu celebración.
      </p>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          site.categorias.map((categoria) => (
            <ServiceCard
              href={`/servicios/${categoria.slug}/`}
              nombre={categoria.nombre}
              emoji={categoria.emoji}
              resumen={categoria.resumen}
              imagen={resolveImage(`${categoria.servicios[0]}-hero`)}
              altImagen={`Actividades de ${categoria.nombre} en un cumpleaños infantil`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <Faq items={faqs.global} />

  <section class="px-4 py-14">
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-4 rounded-3xl bg-menta px-6 py-10 text-center text-white">
      <h2 class="font-titulos text-2xl font-extrabold md:text-3xl">¿Listos para celebrar? 🎉</h2>
      <p class="font-texto text-white/90">
        Escríbenos y armamos juntos la animación perfecta para tu hijo o hija.
      </p>
      <CtaWhatsApp texto="Quiero cotizar mi fiesta" />
    </div>
  </section>
</BaseLayout>
